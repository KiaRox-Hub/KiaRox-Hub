-- Helper function to create settings
local function CreateSetting yPos, labelText, toggle, initialValue, callback
    local settingFrame = Instance.new("Frame")
    settingFrame.Size = UDim2.new(1, 0, 0, 45)
    settingFrame.Position = UDim2.new(0, 0, 0, yPos)
    settingFrame.BackgroundTransparency = 1
    settingFrame.Parent = settingsFrame
    
    -- Label
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 150, 0, 20)
    label.Position = UDim2.new(0, 0, 0, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(200, 200, 200)
    label.Text = labelText
    label.TextSize = 13
    label.Font = Enum.Font.Gotham
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = settingFrame
    
    if toggle then
        -- Toggle Button
        local toggleBtn = Instance.new("TextButton")
        toggleBtn.Size = UDim2.new(0, 50, 0, 24)
        toggleBtn.Position = UDim2.new(1, -60, 0, 0)
        toggleBtn.BackgroundColor3 = initialValue and Color3.fromRGB(76, 175, 80) or Color3.fromRGB(158, 158, 158)
        toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        toggleBtn.Text = initialValue and "ON" or "OFF"
        toggleBtn.TextSize = 11
        toggleBtn.Font = Enum.Font.GothamBold
        toggleBtn.Parent = settingFrame
        
        local toggleBtnCorner = Instance.new("UICorner")
        toggleBtnCorner.CornerRadius = UDim.new(0, 4)
        toggleBtnCorner.Parent = toggleBtn
        
        toggleBtn.MouseButton1Click:Connect(function()
            local newValue = not initialValue
            initialValue = newValue
            toggleBtn.BackgroundColor3 = newValue and Color3.fromRGB(76, 175, 80) or Color3.fromRGB(158, 158, 158)
            toggleBtn.Text = newValue and "ON" or "OFF"
            callback(newValue)
        end)
    else
        -- Value Display
        local valueLabel = Instance.new("TextLabel")
        valueLabel.Size = UDim2.new(0, 50, 0, 20)
        valueLabel.Position = UDim2.new(1, -60, 0, 0)
        valueLabel.BackgroundTransparency = 1
        valueLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        valueLabel.Text = tostring(initialValue)
        valueLabel.TextSize = 13
        valueLabel.Font = Enum.Font.Gotham
        valueLabel.Parent = settingFrame
        
        -- Decrement Button
        local decBtn = Instance.new("TextButton")
        decBtn.Size = UDim2.new(0, 25, 0, 20)
        decBtn.Position = UDim2.new(1, -60, 0, 22)
        decBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
        decBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        decBtn.Text = "-"
        decBtn.TextSize = 14
        decBtn.Font = Enum.Font.GothamBold
        decBtn.Parent = settingFrame
        
        local decCorner = Instance.new("UICorner")
        decCorner.CornerRadius = UDim.new(0, 4)
        decCorner.Parent = decBtn
        
        -- Increment Button
        local incBtn = Instance.new("TextButton")
        incBtn.Size = UDim2.new(0, 25, 0, 20)
        incBtn.Position = UDim2.new(1, -30, 0, 22)
        incBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
        incBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        incBtn.Text = "+"
        incBtn.TextSize = 14
        incBtn.Font = Enum.Font.GothamBold
        incBtn.Parent = settingFrame
        
        local incCorner = Instance.new("UICorner")
        incCorner.CornerRadius = UDim.new(0, 4)
        incCorner.Parent = incBtn
        
        decBtn.MouseButton1Click:Connect(function()
            callback(initialValue - 1, valueLabel)
        end)
        
        incBtn.MouseButton1Click:Connect(function()
            callback(initialValue + 1, valueLabel)
        end)
    end
    
    return settingFrame
end

