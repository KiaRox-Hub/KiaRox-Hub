-- == INPUT HANDLING ==


-- Handle aim keybind
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end


if input.KeyCode == Config.AimKeybind then
    Config.AimEnabled = not Config.AimEnabled
    
    -- Update UI toggle
    if MainFrame then
        local aimToggle = MainFrame.SettingsFrame:FindFirstChild("Frame") and MainFrame.SettingsFrame.Frame:FindFirstChild("TextButton")
        if aimToggle then
            aimToggle.BackgroundColor3 = Config.AimEnabled and Color3.fromRGB(76, 175, 80) or Color3.fromRGB(158, 158, 158)
            aimToggle.Text = Config.AimEnabled and "ON" or "OFF"
        end
    end
end

-- Toggle UI visibility with Insert key
if input.KeyCode == Enum.KeyCode.Insert then
    if MainFrame then
        MainFrame.Visible = not MainFrame.Visible
        ToggleBtn.Text = MainFrame.Visible and "Hide" or "Show"
        IsOpen = MainFrame.Visible
    end
end

-- Switch target with Tab key
if input.KeyCode == Enum.KeyCode.Tab then
    SwitchTarget()
end

end)


